      "parameters": {
        "url": "={{$json.link}}",
        "options": {
          "redirect": {
            "redirect": {
              "followRedirects": true
            }
          },
          "response": {
            "response": {
              "neverError": true,
              "responseFormat": "text",
              "fullResponse": true
            }
          }
        }
      },
