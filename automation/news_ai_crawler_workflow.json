      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{$json.relevant}}",
              "value2": true
            }
          ]
        }
      },
      "id": "filter-relevant-node",
      "name": "Filter Relevant News",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        1360,
        300
      ]
    },
